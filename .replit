modules = ["python-3.11"]

[agent]
expertMode = true

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[workflows]
runButton = "Project"

# --- Primary workflow shown on the Run button ---
[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Plant Breeder Sim Server"

# --- Actual server workflow ---
[[workflows.workflow]]
name = "Plant Breeder Sim Server"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
# Wrap in a shell so $PORT expands; default to 5000 to match waitForPort/localPort
args = "bash -lc \"python -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-5000} --proxy-headers\""
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80
